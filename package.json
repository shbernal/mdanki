{
  "name": "@shbernal/mdanki",
  "version": "1.1.5",
  "description": "Convert Markdown files to Anki cards.",
  "keywords": [
    "anki",
    "markdown",
    "cli",
    "flashcards",
    "deck-generation"
  ],
  "type": "module",
  "packageManager": "pnpm@11.4.0+sha512.f0febc7e37552ab485494a914241b338e0b3580b93d54ce31f00933015880863129038a1b4ae4e414a0ee63ac35bf21197e990172c4a68256450b5636310968f",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": "./dist/bin.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "mdanki": "./dist/bin.js"
  },
  "files": [
    "dist",
    "resources"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "format": "prettier --list-different . | xargs -r prettier --write",
    "lint": "eslint . --ext .ts --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "pnpm run build"
  },
  "author": "shbernal <shbernal.01@gmail.com>",
  "homepage": "https://github.com/shbernal/mdanki",
  "repository": {
    "type": "git",
    "url": "https://github.com/shbernal/mdanki.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@shbernal/anki-apkg-export": "^4.0.6",
    "fast-glob": "^3.3.3",
    "marked": "^18.0.4",
    "marked-highlight": "^2.2.4",
    "prismjs": "^1.30.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/prismjs": "^1.26.6",
    "@types/sql.js": "^1.4.11",
    "@types/yargs": "^17.0.35",
    "@vitest/eslint-plugin": "^1.6.18",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  }
}
