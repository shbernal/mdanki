{
  "name": "@shbernal/mdanki",
  "version": "1.0.0",
  "description": "Convert markdown files to anki cards",
  "keywords": [
    "anki",
    "markdown"
  ],
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": "./dist/bin.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "mdanki": "./dist/bin.js"
  },
  "files": [
    "dist",
    "resources"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint . --ext .ts --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "pnpm run build"
  },
  "author": "shbernal <shbernal.01@gmail.com>",
  "homepage": "https://github.com/shbernal/mdanki",
  "repository": {
    "type": "git",
    "url": "https://github.com/shbernal/mdanki.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@shbernal/anki-apkg-export": "^1.0.0",
    "fast-glob": "^3.3.3",
    "marked": "^17.0.1",
    "marked-highlight": "^2.2.3",
    "prismjs": "^1.30.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.6",
    "@types/prismjs": "^1.26.5",
    "@types/sql.js": "^1.4.9",
    "@types/yargs": "^17.0.35",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-vitest": "^0.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0",
    "vitest": "^4.0.16"
  }
}
